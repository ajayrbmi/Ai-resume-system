# Server
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/resumeai?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-super-long-jwt-secret-here-change-in-production
JWT_EXPIRE=30d

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI
OPENAI_API_KEY=sk-your-openai-key-here
MODEL=gpt-4o-mini

# File Upload
MAX_FILE_SIZE=5MB
UPLOAD_PATH=./uploads

# Production
NODE_ENV=development

